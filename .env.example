# ─────────────────────────────────────────
# ShiftWise – Root Environment Variables
# Copy this file to .env and fill in values
# ─────────────────────────────────────────

# ── PostgreSQL (Docker) ──
POSTGRES_USER=shiftwise
POSTGRES_PASSWORD=shiftwise_secret
POSTGRES_DB=shiftwise_db

# ── Backend ──
DATABASE_URL="postgresql://shiftwise:shiftwise_secret@localhost:5432/shiftwise_db?schema=public"
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# ── Clerk (Authentication) ──
CLERK_SECRET_KEY=sk_test_IQ24rTduyplFhErBCyTvOPwLV7pe3EEtzQ8hZH19JE
CLERK_PUBLISHABLE_KEY=pk_test_dmlhYmxlLXZ1bHR1cmUtNDguY2xlcmsuYWNjb3VudHMuZGV2JA

# ── Cloudflare R2 (File Storage) ──
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=shiftwise-documents
R2_PUBLIC_URL=https://your-bucket.r2.dev

# ── Frontend (Next.js) ──
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=ppk_test_dmlhYmxlLXZ1bHR1cmUtNDguY2xlcmsuYWNjb3VudHMuZGV2JA
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000
