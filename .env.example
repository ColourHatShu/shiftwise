# ─────────────────────────────────────────
# ShiftWise – Root Environment Variables
# This file is checked into git. NEVER put real secrets here.
# Copy this file to .env and fill in real values.
# ─────────────────────────────────────────

# ── PostgreSQL (Docker) ──
POSTGRES_USER=shiftwise
POSTGRES_PASSWORD=changeme
POSTGRES_DB=shiftwise_db

# ── Backend ──
DATABASE_URL="postgresql://shiftwise:changeme@localhost:5432/shiftwise_db?schema=public"
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# ── Clerk (Authentication) ──
CLERK_SECRET_KEY=sk_test_REPLACE_ME
CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME

# ── Cloudflare R2 (File Storage) ──
R2_ACCOUNT_ID=your-cloudflare-account-id-here
R2_ACCESS_KEY_ID=your-r2-access-key-id-here
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key-here
R2_BUCKET_NAME=shiftwise-documents
R2_PUBLIC_URL=https://your-bucket.r2.dev

# ── Frontend (Next.js) ──
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000
