# ─── Backend Environment Variables ───────────────────────────────────────────
# This file is checked into git. NEVER put real secrets here.
# Copy this to .env and fill in your real values.
# ⚠️  All secrets must be rotated before use and never committed!

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
# Public origin(s) allowed by CORS. Comma-separated for multi-env support.
CORS_ORIGIN=http://localhost:3000
# Clerk JWT 'authorized party' claim — must match the frontend origin.
AUTHORIZED_PARTY=http://localhost:3000
# Frontend deep-link base used in email CTAs (worker portal, dashboard, etc.).
FRONTEND_URL=http://localhost:3000
# Backend self-reference used by audit-pack signed URLs and webhooks.
BACKEND_URL=http://localhost:3001
# Display URL printed in PDFs, emails, etc. (often same as FRONTEND_URL).
APP_URL=http://localhost:3000

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://shiftwise:changeme@localhost:5432/shiftwise_db?schema=public"

# ─── Clerk Authentication (Get from https://dashboard.clerk.com) ────────────
CLERK_SECRET_KEY=sk_test_REPLACE_ME
CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME

# ─── Worker Self-Service JWT ─────────────────────────────────────────────────
# REQUIRED in production. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# The server refuses to boot in NODE_ENV=production if this is unset.
JWT_SECRET=replace-me-with-48-random-bytes

# ─── Cloudflare R2 Storage ───────────────────────────────────────────────────
R2_ACCOUNT_ID=your-cloudflare-account-id-here
R2_ACCESS_KEY_ID=your-r2-access-key-id-here
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key-here
R2_BUCKET_NAME=shiftwise-documents
R2_PUBLIC_URL=https://your-bucket.r2.dev

# ─── Document Encryption ─────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DOCUMENT_ENCRYPTION_KEY=your-encryption-key-here

# ─── Email (Resend — https://resend.com) ─────────────────────────────────────
# Leave empty in development to no-op email sends.
RESEND_API_KEY=
# Optional: SMTP fallback for nodemailer.js when not using Resend.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ─── Observability (Sentry — optional, no-op when unset) ─────────────────────
SENTRY_DSN_BACKEND=

# ─── Developer Test Endpoints ────────────────────────────────────────────────
# Set to 'true' to allow /api/alerts/{test,reset-test} in production.
# Default behavior: blocked in production via NODE_ENV check.
ALLOW_ALERT_TEST_ENDPOINTS=false
