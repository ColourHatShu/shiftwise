# ─── Frontend Environment Variables ──────────────────────────────────────────
# Copy this to .env.local and fill in your values

# Clerk Authentication (Public keys safe to expose)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_dmlhYmxlLXZ1bHR1cmUtNDguY2xlcmsuYWNjb3VudHMuZGV2JA
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# Backend API
NEXT_PUBLIC_API_URL=http://localhost:3001

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Sentry (optional — leave empty to disable client-side error reporting in dev)
NEXT_PUBLIC_SENTRY_DSN=